{
    "capturePath": "~/Desktop",
    "target": "scroll_capture",
    "fileFormat": "scroll_rect_%d_%T",
    "scrollConfig": {
        "maxScrolls": 3,
        "scrollDelay": 0.5,
        "regionMode": "rect",
        "region": {
            "x": 0,
            "y": 50,
            "width": 800,
            "height": 600
        }
    }
}
